# Production build overrides for the AI proxy. Copy this to `.env.production.local`
# (which is git-ignored via `*.local`) so it applies ONLY to `npm run build`.
#
# The Firebase VITE_FIREBASE_* vars are still read from your existing `.env`, so
# you only need the OpenAI overrides here.

# Empty on purpose: this strips the dev key from the production bundle and puts
# the app into proxy mode (auth via the user's Firebase ID token).
VITE_OPENAI_API_KEY=

# Your deployed Cloudflare Worker proxy. The app calls {this}/chat/completions.
VITE_OPENAI_BASE_URL=https://excellent-openai-proxy.<subdomain>.workers.dev/v1

# Optional: must be allowed by OPENAI_MODEL_ALLOWLIST in worker/wrangler.toml.
VITE_OPENAI_MODEL=gpt-4o-mini
