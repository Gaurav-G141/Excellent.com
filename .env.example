# From Firebase Console → Project Settings → Your apps → Web app
# Or run: firebase apps:sdkconfig WEB
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# OpenAI — powers the Applications tab's AI problem rewrites + mad-lib themes.
# Get a key at https://platform.openai.com/api-keys
# ⚠️ This value ships in the public browser bundle (all VITE_* vars do). Fine for
#    local dev / trusted demos; for a public site, proxy it (see docs/openai-setup.md).
VITE_OPENAI_API_KEY=
# Optional overrides:
VITE_OPENAI_MODEL=gpt-4o-mini
# VITE_OPENAI_BASE_URL=https://api.openai.com/v1
